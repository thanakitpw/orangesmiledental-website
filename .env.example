# Supabase — fill these in after creating the project.
# Images are served from Supabase Storage when NEXT_PUBLIC_SUPABASE_URL is set;
# otherwise the site falls back to the local /public/media copies.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Storage bucket that holds every site image (created by the migration).
NEXT_PUBLIC_SUPABASE_MEDIA_BUCKET=media

# Server-only. Needed by `npm run media:upload` to write to Storage + media_assets.
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=
